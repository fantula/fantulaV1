\n  align-items: flex-start;\n  justify-content: center;\n  width: 100%;\n  margin: 0 auto;\n  max-width: 1300px;\n}\n.privacy-col {\n  flex: 1;\n  background: transparent;\n  border-radius: 12px;\n  padding: 0 0 32px 0;\n  font-size: 15px;\n  color: #CBD5E1;\n  display: flex;\n  flex-direction: column;\n}\n.privacy-col-cn {\n  margin-right: 0;\n}\n.privacy-col-en {\n  margin-left: 0;\n}\n.privacy-col-cn-main,\n.privacy-col-en-main {\n  width: 42vw;\n  max-width: 600px;\n  min-width: 400px;\n  min-height: 800px;\n  height: auto;\n  border-radius: 16px;\n  box-sizing: border-box;\n  padding: 24px;\n  /* Inner Glass Card */\n  background: rgba(15, 23, 42, 0.4);\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  position: relative;\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n.privacy-section-title,\n.privacy-en-section-title {\n  color: #60A5FA; /* Blue-400 */\n  font-weight: bold;\n  font-size: 22px;\n  border-left: 4px solid #60A5FA;\n  padding-left: 12px;\n  margin-top: 32px;\n  margin-bottom: 0;\n  line-height: 79px;\n  font-family: 'Noto Sans SC-Black', 'Noto Sans Black', 'Noto Sans', 'Noto Sans SC', Arial, sans-serif;\n  height: 54px;\n  display: flex;\n  align-items: center;\n}\n.privacy-section {\n  margin-bottom: 16px;\n  line-height: 1.9;\n  color: #CBD5E1; /* Slate-300 */\n}\n.privacy-highlight {\n  background: rgba(96, 165, 250, 0.15);\n  color: #60A5FA;\n  padding: 2px 6px;\n  border-radius: 6px;\n}\n.privacy-contact {\n  color: #60A5FA;\n  font-weight: bold;\n  font-size: 16px;\n}\n.privacy-section-tip {\n  background: rgba(255, 255, 255, 0.05);\n  color: #94A3B8;\n  border-radius: 8px;\n  padding: 10px 16px;\n  margin-top: 18px;\n  font-size: 14px;\n}\n.privacy-list {\n  margin: 8px 0 16px 24px;\n  padding: 0;\n  list-style: disc;\n  color: #CBD5E1;\n  font-size: 15px; /* Adjusted size */\n}\n.privacy-section-desc {\n  margin-bottom: 2px;\n  color: #E2E8F0; /* Slate-200 */\n  font-size: 16px;\n  font-weight: 500;\n}\n.privacy-section-h