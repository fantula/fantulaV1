AAA,EAAA,SAAA,OAAA;AAAA,0BACZ,UAAA;AAAA,wBACS,GAAA;AAAA;6BAGoBS,UAAA,IAAA,GAAAC,YAAAG,UAAA,MAAAC,WAAA,aAAA,OAAA,CAAA,QAAA;;gCAI3B,KAAA,IAAA;AAAA,gCAHU,OAAA,IAAA;AAAA,gCACE,OAAA,IAAA;AAAA,8BACA,GAAA,MAAA,GAAA,CAAA,SAAA,OAAA,CAAA;AAAA;;;;;;;;sBAMQ,SAAAf,QAAA,MAAA;AAAA,wBAeZC,YAAA,sBAAA;AAAA,0BAAA,YAAA,kBAAA;AAAA,0BAbD,uBAAA,CAAA,WAAA,kBAAA,QAAA;AAAA,0BAAiB,aAAA;AAAA,0BACd,YAAA;AAAA,0BACZ,UAAA,CAAA,mBAAA;AAAA,0BACY,OAAA,EAAA,SAAA,OAAA;AAAA,0BACZ,gBAAA;AAAA,wBACa,GAAA;AAAA;6BAGgBS,UAAA,IAAA,GAAAC,YAAAG,UAAA,MAAAC,WAAA,YAAA,OAAA,CAAA,SAAA;;gCAI3B,KAAA,KAAA;AAAA,gCAHW,OAAA,KAAA;AAAA,gCACE,OAAA,KAAA;AAAA,8BACA,GAAA,MAAA,GAAA,CAAA,SAAA,OAAA,CAAA;AAAA;;;;;;;;;;;;;;;gBApCQ,SAAAf,QAAA,MAAA;AAAA,kBAGZC,YAAA,yBAAA,EAAA,OAAA,OAAA,GAAA;AAAA,oBAFW,SAAAD,QAAA,MAAA;AAAA,sBACoCC,YAAA,qBAAA;AAAA,wBAAA,eAAA,WAAA,OAAA;AAAA,wBAAxB,UAAA;AAAA,sBAAa,GAAA,MAAA,GAAA,CAAA,aAAA,CAAA;AAAA;;;;oBAIzB,SAAAD,QAAA,MAAA;AAAA,sBAaZC,YAAA,sBAAA;AAAA,wBAAA,YAAA,mBAAA;AAAA,wBAXD,uBAAA,CAAA,WAAA,mBAAA,QAAA;AAAA,wBAAkB,aAAA;AAAA,wBACf,OAAA,EAAA,SAAA,OAAA;AAAA,wBACZ,UAAA;AAAA,sBACS,GAAA;AAAA;2BAGoBS,UAAA,IAAA,GAAAC,YAAAG,UAAA,MAAAC,WAAA,aAAA,OAAA,CAAA,QAAA;;8BAI3B,KAAA,IAAA;AAAA,8BAHU,OAAA,IAAA;AAAA,8BACE,OAAA,IAAA;AAAA,4BACA,GAAA,MAAA,GAAA,CAAA,SAAA,OAAA,CAAA;AAAA;;;;;;;;oBAMQ,SAAAf,QAAA,MAAA;AAAA,sBAeZC,YAAA,sBAAA;AAAA,wBAAA,YAAA,kBAAA;AAAA,wBAbD,uBAAA,CAAA,WAAA,kBAAA,QAAA;AAAA,wBAAiB,aAAA;AAAA,wBACd,YAAA;AAAA,wBACZ,UAAA,CAAA,mBAAA;AAAA,wBACY,OAAA,EAAA,SAAA,OAAA;AAAA,wBACZ,gBAAA;AAAA,sBACa,GAAA;AAAA;2BAGgBS,UAAA,IAAA,GAAAC,YAAAG,UAAA,MAAAC,WAAA,YAAA,OAAA,CAAA,SAAA;;8BAI3B,KAAA,KAAA;AAAA,8BAHW,OAAA,KAAA;AAAA,8BACE,OAAA,KAAA;AAAA,4BACA,GAAA,MAAA,GAAA,CAAA,SAAA,OAAA,CAAA;AAAA;;;;;;;;;;;;;;;;;QAcH,uBAAA,CAAA,WAAA,kBAAA,QAAA;AAAA,QAAiB,OAAA;AAAA,QAAQ,OAAA;AAAA,MAAe,GAAA;AAAA;;;;;YAalB,GAAA;AAAA;;;;;;kBAAY;AAAA;;;;;;cAChC,SAAA;AAAA,cAAkB,SAAA,YAAA;AAAA,YAA0B,GAAA;AAAA;;;;;;kBAAiB;AAAA;;;;;;;;gBAFpDd,YAAA,sBAAA;AAAA,kBACmC,SAAA,CAAA,WAAA,kBAAA,QAAA;AAAA,gBAAxB,GAAA;AAAA;oBAAYI,gBAAA,IAAA;AAAA,kBAAA,CAAA;AAAA;;;kBACyC,MAAA;AAAA,kBAAzE,SAAA;AAAA,kBAAkB,SAAA,YAAA;AAAA,gBAA0B,GAAA;AAAA;oBAAiBA,gBAAA,MAAA;AAAA,kBAAA,CAAA;AAAA;;;;;;;;;;;cAZ/D,MAAA;AAAA,cAA0C,UAAA;AAAA,cAAkB,aAAA;AAAA,YAAO,GAAA,MAAA,UAAA,QAAA,CAAA;;;cAExE,uBAAA,CAAA,WAAA,WAAA,QAAA;AAAA,cAAU,MAAA;AAAA,cACd,MAAA;AAAA,cACE,aAAA;AAAA,cACK,OAAA,EAAA,cAAA,OAAA;AAAA,YACZ,GAAA,MAAA,UAAA,QAAA,CAAA;;;;;gBAPsBJ,YAAA,qBAAA;AAAA,kBACuE,OAAA;AAAA,kBAA/E,MAAA;AAAA,kBAA0C,UAAA;AAAA,kBAAkB,aAAA;AAAA,gBAAO,CAAA;AAAA;kBAOjF,YAAA,WAAA;AAAA,kBALS,uBAAA,CAAA,WAAA,WAAA,QAAA;AAAA,kBAAU,MAAA;AAAA,kBACd,MAAA;AAAA,kBACE,aAAA;AAAA,kBACK,OAAA,EAAA,cAAA,OAAA;AAAA,gBACZ,GAAA,MAAA,GAAA,CAAA,cAAA,qBAAA,CAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_withCtx","_createVNode","_unref","Search","_withKeys","_createTextVNode","_ssrRenderComponent","Plus","Refresh","_toDisplayString","_openBlock","_createBlock","_ssrInterpolate","_ssrRenderList","_Fragment","_renderList"],"sources":["../../../../pages/admin/cdk/channel-recognition.vue"],"sourcesContent":["<template>\n  <div class=\"channel-recognition-page\">\n    <!-- Action Bar -->\n    <AdminActionCard>\n      <template #default>\n        <div class=\"filter-group\">\n          <el-input\n            v-model=\"searchQuery\"\n            placeholder=\"搜索频道标识...\"\n            style=\"width: 240px\"\n            clearable\n            @clear=\"fetchData\"\n            @keyup.enter=\"fetchData\"\n          >\n            <template #prefix>\n              <el-icon><Search /></el-icon>\n            </template>\n          </el-input>\n          \n          <el-select \n            v-model=\"filterStatus\" \n            placeholder=\"状态筛选\" \n            style=\"width: 140px\" \n            @change=\"fetchData\"\n          >\n            <el-option label=\"全部\" value=\"all\" />\n            <el-option label=\"待处理 (未绑定)\" value=\"unbound\" />\n            <el-option label=\"已完成 (已绑定)\" value=\"bound\" />\n          </el-select>\n          \n          <el-button type=\"primary\" @click=\"fetchData\">查询</el-button>\n        </div>\n      </template>\n\n      <template #actions>\n        <el-button type=\"success\" @click=\"batchModalVisible = true\">\n          <el-icon class=\"el-icon--left\"><Plus /></el-icon>\n          批量添加\n        </el-button>\n        <el-button @click=\"fetchData\">\n          <el-icon><Refresh /></el-icon>\n        </el-button>\n      </template>\n    </AdminActionCard>\n\n    <!-- Data Table -->\n    <AdminDataTable\n      :data=\"tableData\"\n      :loading=\"loading\"\n      :total=\"total\"\n      v-model:current-page=\"currentPage\"\n      v-model:page-size=\"pageSize\"\n      @update:current-page=\"fetchData\"\n      @update:page-size=\"fetchData\"\n    >\n      <el-table-column prop=\"channel_key\" label=\"频道标识\" min-width=\"180\">\n        <template #default=\"{ row }\">\n          <span class=\"channel-key\">{{ row.channel_key }}</span>\n        </template>\n      </el-table-column>\n      \n      <el-table-column label=\"绑定商品\" min-width=\"250\">\n        <template #default=\"{ row }\">\n          <div v-if=\"row.products\" class=\"bound-product\">\n            <el-tag size=\"small\" type=\"success\">已绑定</el-tag>\n            <span class=\"product-name\" :title=\"row.products.product_name\">{{ row.products.product_name }}</span>\n          </div>\n          <el-tag v-else type=\"warning\" size=\"small\">未绑定</el-tag>\n        </template>\n      </el-table-column>\n\n      <el-table-column label=\"状态\" width=\"120\">\n        <template #default=\"{ row }\">\n          <el-tag :type=\"row.product_id ? 'success' : 'warning'\" effect=\"dark\">\n            {{ row.product_id ? '已完成' : '待处理' }}\n          </el-tag>\n        </template>\n      </el-table-column>\n\n      <el-table-column label=\"创建时间\" width=\"180\">\n        <template #default=\"{ row }\">\n          {{ formatDate(row.created_at) }}\n        </template>\n      </el-table-column>\n\n      <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\n        <template #default=\"{ row }\">\n          <el-button link type=\"primary\" @click=\"openBindModal(row)\">\n            {{ row.product_id ? '修改商品' : '绑定商品' }}\n          </el-button>\n          <el-popconfirm \n            title=\"确定要彻底删除该记录吗？下次用户搜索将重新生成。\"\n            confirm-button-text=\"删除\"\n            cancel-button-text=\"取消\"\n            @confirm=\"handleDelete(row)\"\n          >\n            <template #reference>\n              <el-button link type=\"danger\">删除</el-button>\n            </template>\n          </el-popconfirm>\n        </template>\n      </el-table-column>\n    </AdminDataTable>\n\n    <!-- Bind Product Modal -->\n    <el-dialog v-model=\"bindModalVisible\" title=\"绑定商品\" width=\"500px\" destroy-on-close>\n      <el-form label-position=\"top\">\n        <el-form-item label=\"当前频道\">\n          <el-input :model-value=\"currentRow?.channel_key\" disabled />\n        </el-form-item>\n        \n        <!-- Step 1: Category Select -->\n        <el-form-item label=\"选择分类\">\n          <el-select \n            v-model=\"selectedCategoryId\" \n            placeholder=\"请选择商品分类\" \n            style=\"width: 100%\"\n            @change=\"handleCategoryChange\"\n          >\n            <el-option\n              v-for=\"cat in categoryList\"\n              :key=\"cat.id\"\n              :label=\"cat.name\"\n              :value=\"cat.id\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <!-- Step 2: Product Select -->\n        <el-form-item label=\"选择商品\">\n          <el-select \n            v-model=\"selectedProductId\" \n            placeholder=\"请选择商品\" \n            filterable \n            :disabled=\"!selectedCategoryId\"\n            style=\"width: 100%\"\n            no-data-text=\"该分类下暂无商品\"\n          >\n            <el-option\n              v-for=\"item in productList\"\n              :key=\"item.id\"\n              :label=\"item.product_name\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"bindModalVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"handleSaveBind\" :loading=\"saving\" :disabled=\"!selectedProductId\">保存</el-button>\n        </span>\n      </template>\n    </el-dialog>\n\n    <!-- Batch Add Modal -->\n    <el-dialog v-model=\"batchModalVisible\" title=\"批量添加频道\" width=\"500px\">\n      <div class=\"batch-content\">\n        <el-alert title=\"每行输入一个频道标识 (@xxx)，系统会自动去重并生成未绑定记录。\" type=\"info\" :closable=\"false\" show-icon />\n        <el-input\n          v-model=\"batchInput\"\n          type=\"textarea\"\n          :rows=\"10\"\n          placeholder=\"@channel1\\n@channel2\\n...\"\n          style=\"margin-top: 15px;\"\n        />\n      </div>\n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"batchModalVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"handleBatchAdd\" :loading=\"batchAdding\">开始生成</el-button>\n        </span>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'mgmt',\n  middleware: [\"mgmt-auth\"]\n})\n\nimport { ref, onMounted } from 'vue'\nimport { Search, Plus, Refresh } from '@element-plus/icons-vue'\nimport dayjs from 'dayjs'\nimport { getAdminSupabaseClient } from '@/utils/supabase-admin'\nimport AdminActionCard from '@/components/admin/base/AdminActionCard.vue'\nimport AdminDataTable from '@/components/admin/base/AdminDataTable.vue'\n\nconst client = getAdminSupabaseClient()\n\n// --- State ---\nconst loading = ref(false)\nconst tableData = ref<any[]>([])\nconst searchQuery = ref('')\nconst filterStatus = ref('unbound') // Default: Unbound\nconst currentPage = ref(1)\nconst pageSize = ref(10)\nconst total = ref(0)\n\n// Bind Modal State\nconst bindModalVisible = ref(false)\nconst currentRow = ref<any>(null)\nconst selectedCategoryId = ref<string | null>(null)\nconst selectedProductId = ref<string | null>(null)\nconst categoryList = ref<any[]>([])\nconst productList = ref<any[]>([])\nconst saving = ref(false)\n\n// Batch Modal State\nconst batchModalVisible = ref(false)\nconst batchInput = ref('')\nconst batchAdding = ref(false)\n\n// --- Init ---\nonMounted(() => {\n  fetchData()\n  fetchCategories()\n})\n\n// --- Data Fetching ---\nconst fetchData = async () => {\n  loading.value = true\n  try {\n    let query = client\n      .from('channel_recognitions')\n      .select('*, products(id, product_name)', { count: 'exact' })\n      .order('created_at', { ascending: false })\n      .range((currentPage.value - 1) * pageSize.value, currentPage.value * pageSize.value - 1)\n\n    // Search\n    if (searchQuery.value) {\n      query = query.ilike('channel_key', `%${searchQuery.value}%`)\n    }\n\n    // Filter\n    if (filterStatus.value === 'unbound') {\n      query = query.is('product_id', null)\n    } else if (filterStatus.value === 'bound') {\n      query = query.not('product_id', 'is', null)\n    }\n\n    const { data, count, error } = await query\n\n    if (error) throw error\n\n    tableData.value = data || []\n    total.value = count || 0\n  } catch (err: any) {\n    ElMessage.error('加载失败: ' + err.message)\n  } finally {\n    loading.value = false\n  }\n}\n\nconst fetchCategories = async () => {\n  const { data } = await client\n    .from('product_categories')\n    .select('id, name')\n    .eq('status', 'on')\n    .order('sort_order', { ascending: true })\n  categoryList.value = data || []\n}\n\n// --- Actions ---\n\nconst formatDate = (date: string) => {\n  return dayjs(date).format('YYYY-MM-DD HH:mm')\n}\n\nconst handleDelete = async (row: any) => {\n  try {\n    const { error } = await client.from('channel_recognitions').delete().eq('id', row.id)\n    if (error) throw error\n    ElMessage.success('删除成功')\n    fetchData()\n  } catch (err: any) {\n    ElMessage.error('删除失败: ' + err.message)\n  }\n}\n\n// --- Bind Logic ---\n\nconst openBindModal = (row: any) => {\n  currentRow.value = row\n  // Reset selection\n  selectedCategoryId.value = null\n  selectedProductId.value = null\n  productList.value = []\n  \n  // Try to restore if already bound\n  if (row.product_id && row.products) {\n    // If we knew the category_id of the product, we could auto-select.\n    // However, channel_recognitions doesn't store category_id.\n    // It's acceptable to make user re-select for modification, OR we could fetch product details.\n    // Let's try to fetch product details to get category_id.\n    fetchProductDetails(row.product_id)\n  }\n  \n  bindModalVisible.value = true\n}\n\nconst fetchProductDetails = async (productId: string) => {\n  const { data } = await client.from('products').select('category_id').eq('id', productId).single()\n  if (data) {\n    selectedCategoryId.value = data.category_id\n    await handleCategoryChange(data.category_id)\n    selectedProductId.value = productId\n  }\n}\n\nconst handleCategoryChange = async (catId: string) => {\n  selectedCategoryId.value = catId\n  selectedProductId.value = null // reset product\n  \n  if (!catId) {\n    productList.value = []\n    return\n  }\n\n  const { data } = await client\n    .from('products')\n    .select('id, product_name')\n    .eq('category_id', catId)\n    .eq('status', 'on')\n    .order('sort_order', { ascending: true })\n  \n  productList.value = data || []\n}\n\nconst handleSaveBind = async () => {\n  if (!selectedProductId.value) return\n\n  saving.value = true\n  try {\n    const { error } = await client\n      .from('channel_recognitions')\n      .update({ \n        product_id: selectedProductId.value,\n        updated_at: new Date().toISOString()\n      })\n      .eq('id', currentRow.value.id)\n\n    if (error) throw error\n\n    ElMessage.success('绑定成功')\n    bindModalVisible.value = false\n    fetchData()\n  } catch (err: any) {\n    ElMessage.error('保存失败: ' + err.message)\n  } finally {\n    saving.value = false\n  }\n}\n\n// --- Batch Add Logic ---\n\nconst handleBatchAdd = async () => {\n  if (!batchInput.value.trim()) {\n    ElMessage.warning('请输入内容')\n    return\n  }\n\n  batchAdding.value = true\n  try {\n    // 1. Parse and Sanitize\n    const rawLines = batchInput.value.split('\\n')\n    const uniqueKeys = new Set<string>()\n\n    rawLines.forEach(line => {\n      let key = line.trim().toLowerCase()\n      if (!key) return\n      if (!key.startsWith('@')) key = '@' + key\n      uniqueKeys.add(key)\n    })\n\n    if (uniqueKeys.size === 0) {\n      ElMessage.warning('没有有效的频道标识')\n      return\n    }\n\n    // 2. Prepare Payload\n    const payload = Array.from(uniqueKeys).map(key => ({\n      channel_key: key\n      // product_id is null by default\n    }))\n\n    // 3. Upsert (Ignore conflicts means do nothing if exists, which is perfect)\n    const { error } = await client\n      .from('channel_recognitions')\n      .upsert(payload, { onConflict: 'channel_key', ignoreDuplicates: true })\n\n    if (error) throw error\n\n    ElMessage.success(`操作完成：处理 ${payload.length} 条记录`)\n    batchModalVisible.value = false\n    batchInput.value = ''\n    fetchData()\n  } catch (err: any) {\n    ElMessage.error('批量生成失败: ' + err.message)\n  } finally {\n    batchAdding.value = false\n  }\n}\n</script>\n\n<style scoped>\n.channel-recognition-page {\n  padding: 20px;\n  background: #fff;\n  border-radius: 8px;\n}\n\n.filter-group {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n}\n</style>\n"],"version":3}