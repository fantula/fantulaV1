AA,KAAA,0DAAA,IAAA,EAAA,EAAA;AAAA,oBACoF,GAAA;AAAA;wBAGtFG,gBAAA,QAAA;AAAA,sBAAA,CAAA;AAAA;;;;;;;;;;gBAvBwD,MAAA;AAAA,gBAAtC,OAAA;AAAA,gBAAa,aAAA;AAAA,cAAiB,CAAA;AAAA;gBAKlC,MAAA;AAAA,gBAJI,OAAA;AAAA,gBAAmB,aAAA;AAAA,cAAiB,GAAA;AAAA;kBAC/BE,YAAA,mBAAA,MAAA;AAAA,oBACc,SAAAH,QAAA,MAAA;AAAA,sBAATC,gBAAAC,gBAAA,IAAA,UAAA,GAAA,CAAA;AAAA,oBAAH,CAAA;AAAA;;;;;;gBAWX,OAAA;AAAA,gBARK,OAAA;AAAA,gBAAa,OAAA;AAAA,cAAY,GAAA;AAAA;kBACrBC,YAAA,sBAAA;AAAA,oBAKrB,YAAA,IAAA;AAAA,oBAHa,uBAAA,CAAA,WAAA,IAAA,aAAA;AAAA,oBAAU,SAAA,IAAA;AAAA,oBACT,UAAA,CAAA,WAAA,aAAA,GAAA;AAAA,kBACW,GAAA,MAAA,GAAA,CAAA,cAAA,uBAAA,WAAA,UAAA,CAAA;AAAA;;;;gBAcb,OAAA;AAAA,gBAVK,OAAA;AAAA,gBAAW,OAAA;AAAA,cAAY,GAAA;AAAA;kBACnBA,YAAA,sBAAA;AAAA,oBAOX,MAAA;AAAA,oBALL,MAAA;AAAA,oBACL,SAAA,CAAA,WAAAL,MAAA,MAAA,EAAA,KAAA,0DAAA,IAAA,EAAA,EAAA;AAAA,kBACoF,GAAA;AAAA;sBAGtFG,gBAAA,QAAA;AAAA,oBAAA,CAAA;AAAA;;;;;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_withCtx","_createTextVNode","_toDisplayString","_createVNode"],"sources":["../../../../pages/manager_portal/backend-settings/notification/index.vue"],"sourcesContent":["<template>\n  <div class=\"notification-list-page\">\n    <div class=\"page-header\">\n      <h3>邮件通知配置</h3>\n      <el-button :icon=\"Refresh\" circle @click=\"() => refresh()\" :loading=\"pending\" />\n    </div>\n\n    <AdminDataTable\n      :data=\"templates\"\n      :loading=\"pending\"\n      :total=\"templates.length\"\n      :show-pagination=\"false\"\n    >\n      <el-table-column prop=\"name\" label=\"通知名称\" min-width=\"150\" />\n      <el-table-column prop=\"event_type\" label=\"事件类型\" min-width=\"150\">\n        <template #default=\"{ row }\">\n          <el-tag>{{ row.event_type }}</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"启用状态\" width=\"100\" align=\"center\">\n        <template #default=\"{ row }\">\n          <el-switch\n            v-model=\"row.is_enabled\"\n            :loading=\"row.updating\"\n            @change=\"handleToggle(row)\"\n          />\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"120\" align=\"center\">\n        <template #default=\"{ row }\">\n          <el-button \n            type=\"primary\" \n            link \n            @click=\"router.push(`/manager_portal/backend-settings/notification/template/${row.id}`)\"\n          >\n            编辑模板\n          </el-button>\n        </template>\n      </el-table-column>\n    </AdminDataTable>\n\n\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref } from 'vue'\nimport { Refresh } from '@element-plus/icons-vue'\nimport AdminDataTable from '@/components/admin/base/AdminDataTable.vue'\n\ndefinePageMeta({\n  layout: 'mgmt',\n  middleware: [\"mgmt-auth\"]\n})\n\nconst router = useRouter()\nconst { data: res, pending, refresh, error } = await useFetch('/api/admin/system/notifications/templates')\n\nconst templates = computed(() => res.value?.data || [])\n\nconst handleToggle = async (row: any) => {\n  row.updating = true\n  try {\n    const { error } = await useFetch('/api/admin/system/notifications/templates', {\n      method: 'POST',\n      body: {\n        id: row.id,\n        event_type: row.event_type, // Required by validation\n        is_enabled: row.is_enabled\n      }\n    })\n    \n    if (error.value) {\n      ElMessage.error(error.value.statusMessage || '更新失败')\n      row.is_enabled = !row.is_enabled // revert\n    } else {\n      ElMessage.success('更新成功')\n    }\n  } catch (e) {\n    ElMessage.error('更新失败')\n    row.is_enabled = !row.is_enabled\n  } finally {\n    row.updating = false\n  }\n}\n</script>\n\n<style scoped>\n.notification-list-page {\n  padding: 20px;\n  background: var(--el-bg-color);\n  border-radius: 8px;\n}\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n.page-header h3 {\n  margin: 0;\n}\n</style>\n"],"version":3}