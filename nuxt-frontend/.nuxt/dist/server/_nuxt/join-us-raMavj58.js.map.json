{"file":"join-us-raMavj58.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiIA,YAAA;AAAA,MAAQ,OAAA;AAAA,MACC,MAAA;AAAA,QACD,EAAA,MAAA,eAAA,SAAA,sCAAA;AAAA,MACkE;AAAA,IACxE,CAAA;;;AApIK,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAA,kBAAA,MAAA,CAAA,CAAA,4lBAAA;;;;;;;;YAoBiD;AAAA;;;;;;;;;;;;YAOH;AAAA;;;;;;;;;;;;YAOM;AAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps"],"sources":["../../../../pages/pc/join-us.vue"],"sourcesContent":["<template>\n  <div class=\"join-us-page\">\n    <div class=\"page-content\">\n      <div class=\"content-container\">\n        \n        <!-- Header -->\n        <div class=\"header-section\">\n          <h1 class=\"main-title\">招贤纳士</h1>\n          <h2 class=\"sub-title\">加入凡图拉，共同构建全球化的数字权益服务生态</h2>\n        </div>\n\n        <!-- Intro -->\n        <div class=\"intro-section\">\n          <p class=\"intro-text\">\n            凡图拉正在寻找充满激情、富有创新精神的伙伴。我们是一个推崇“远程优先、结果导向”的数字化团队。在这里，没有复杂的办公室政治，只有对卓越服务的共同追求。如果你对全球互联网服务、数字化产品感兴趣，渴望在一个自由开放的氛围中工作，欢迎加入我们。\n          </p>\n        </div>\n\n        <!-- Values Grid -->\n        <div class=\"values-grid\">\n          <div class=\"value-item\">\n            <div class=\"value-icon\"><el-icon><Monitor /></el-icon></div>\n            <div class=\"value-info\">\n              <h3>远程协作</h3>\n              <p>100% 远程办公文化，灵活安排时间，让工作与生活完美平衡。</p>\n            </div>\n          </div>\n          <div class=\"value-item\">\n            <div class=\"value-icon\"><el-icon><Flag /></el-icon></div>\n            <div class=\"value-info\">\n              <h3>全球视野</h3>\n              <p>接触全球前沿的数字权益产品，拓展国际化的互联网视野。</p>\n            </div>\n          </div>\n          <div class=\"value-item\">\n            <div class=\"value-icon\"><el-icon><UserFilled /></el-icon></div>\n            <div class=\"value-info\">\n              <h3>用户至上</h3>\n              <p>我们用心服务每一位用户，每一份反馈都值得被认真对待。</p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Open Positions -->\n        <div class=\"positions-section\">\n          <h3 class=\"section-title\">开放职位</h3>\n          \n          <!-- Position 1 -->\n          <div class=\"position-card\">\n            <div class=\"pos-header\">\n              <div class=\"pos-info\">\n                <h4 class=\"pos-title\">数字化服务专员 (客服方向)</h4>\n                <div class=\"pos-tags\">\n                  <span class=\"tag\">远程办公</span>\n                  <span class=\"tag\">全职/兼职</span>\n                  <span class=\"tag\">急聘</span>\n                </div>\n              </div>\n              <div class=\"pos-action\">\n                <a href=\"mailto:hr@fantula.com?subject=应聘-数字化服务专员\" class=\"apply-btn\">投递简历</a>\n              </div>\n            </div>\n            <div class=\"pos-desc\">\n              <p><strong>岗位职责：</strong></p>\n              <ul>\n                <li>通过在线工单系统（WeChat/Telegram）回复用户关于权益订阅、兑换流程的咨询；</li>\n                <li>协助用户解决订单交付中的异常问题，维护良好的用户满意度；</li>\n                <li>收集由于服务商政策调整带来的常见问题，反馈给运营团队。</li>\n              </ul>\n              <p><strong>任职要求：</strong></p>\n              <ul>\n                <li>熟悉主流互联网产品（如 Netflix, Spotify 等）的订阅机制；</li>\n                <li>具备良好的沟通耐心和服务意识，中英文读写流利者优先；</li>\n                <li>有稳定的网络环境与电脑设备。</li>\n              </ul>\n            </div>\n          </div>\n\n          <!-- Position 2 -->\n          <div class=\"position-card\">\n            <div class=\"pos-header\">\n              <div class=\"pos-info\">\n                <h4 class=\"pos-title\">数字权益运营专员</h4>\n                <div class=\"pos-tags\">\n                  <span class=\"tag\">远程办公</span>\n                  <span class=\"tag\">全职</span>\n                </div>\n              </div>\n              <div class=\"pos-action\">\n                <a href=\"mailto:hr@fantula.com?subject=应聘-数字权益运营\" class=\"apply-btn\">投递简历</a>\n              </div>\n            </div>\n            <div class=\"pos-desc\">\n              <p><strong>岗位职责：</strong></p>\n              <ul>\n                <li>负责拓展与维护全球数字权益供应商关系，确保供应链稳定；</li>\n                <li>监控各类权益商品的市场价格波动与库存情况，及时调整上架策略；</li>\n                <li>优化自动化交付流程，协同技术团队降低订单失败率。</li>\n              </ul>\n              <p><strong>任职要求：</strong></p>\n              <ul>\n                <li>对数字虚拟商品行业有敏锐的洞察力；</li>\n                <li>具备数据分析能力，能根据销售数据优化选品策略；</li>\n                <li>严谨细致，具有较强的风险合规意识。</li>\n              </ul>\n            </div>\n          </div>\n\n        </div>\n\n        <!-- Contact HR -->\n        <div class=\"hr-contact\">\n          <p>更多职位正在开放中，如果您认为自己足够优秀，欢迎直接发送简历至</p>\n          <a href=\"mailto:hr@fantula.com\" class=\"hr-email\">hr@fantula.com</a>\n          <p class=\"hr-tip\">邮件标题请注明：姓名+应聘岗位</p>\n        </div>\n\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'pc'\n})\n\nimport { Monitor, Flag, UserFilled } from '@element-plus/icons-vue'\n\nuseHead({\n  title: '招贤纳士 - 凡图拉',\n  meta: [\n    { name: 'description', content: '加入凡图拉，探索全球数字化权益服务。远程办公，全球视野，期待您的加入。' }\n  ]\n})\n</script>\n\n<style scoped>\n/* Dark Aurora Theme Consistency */\n.join-us-page {\n  min-height: 100vh;\n  background: transparent;\n  display: flex;\n  flex-direction: column;\n}\n\n.page-content {\n  flex: 1;\n  width: 100%;\n  padding: 60px 20px;\n  display: flex;\n  justify-content: center;\n}\n\n.content-container {\n  width: 100%;\n  max-width: 1100px; /* Slightly narrower for reading */\n  background: rgba(30, 41, 59, 0.7);\n  backdrop-filter: blur(20px);\n  -webkit-backdrop-filter: blur(20px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 24px;\n  padding: 60px 50px;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);\n  display: flex;\n  flex-direction: column;\n  margin: 0 auto;\n}\n\n.header-section {\n  text-align: center;\n  margin-bottom: 50px;\n}\n\n.main-title {\n  font-family: 'Outfit', sans-serif;\n  font-weight: 700;\n  font-size: 42px;\n  background: linear-gradient(135deg, #60A5FA 0%, #F97316 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n  margin-bottom: 16px;\n}\n\n.sub-title {\n  font-family: 'Noto Sans SC', sans-serif;\n  font-size: 18px;\n  color: #94A3B8;\n  font-weight: 400;\n  margin: 0;\n}\n\n.intro-section {\n  text-align: center;\n  margin-bottom: 60px;\n  max-width: 800px;\n  align-self: center;\n}\n\n.intro-text {\n  font-size: 16px;\n  color: #CBD5E1;\n  line-height: 1.8;\n}\n\n/* Values Grid */\n.values-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 30px;\n  margin-bottom: 60px;\n}\n\n.value-item {\n  background: rgba(15, 23, 42, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  border-radius: 16px;\n  padding: 30px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  transition: transform 0.3s ease;\n}\n\n.value-item:hover {\n  transform: translateY(-5px);\n  background: rgba(30, 41, 59, 0.6);\n  border-color: rgba(96, 165, 250, 0.3);\n}\n\n.value-icon {\n  width: 50px;\n  height: 50px;\n  background: rgba(96, 165, 250, 0.1);\n  border-radius: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 20px;\n  font-size: 24px;\n  color: #60A5FA;\n}\n\n.value-info h3 {\n  font-size: 18px;\n  color: #F8FAFC;\n  margin: 0 0 10px 0;\n}\n\n.value-info p {\n  font-size: 14px;\n  color: #94A3B8;\n  line-height: 1.6;\n  margin: 0;\n}\n\n/* Positions */\n.positions-section {\n  margin-bottom: 50px;\n}\n\n.section-title {\n  font-size: 24px;\n  color: #E2E8F0;\n  margin-bottom: 30px;\n  border-left: 4px solid #F97316;\n  padding-left: 15px;\n  font-weight: 600;\n}\n\n.position-card {\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  border-radius: 16px;\n  padding: 30px;\n  margin-bottom: 24px;\n  transition: all 0.3s ease;\n}\n\n.position-card:hover {\n  background: rgba(255, 255, 255, 0.05);\n  border-color: rgba(96, 165, 250, 0.3);\n}\n\n.pos-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  margin-bottom: 20px;\n  flex-wrap: wrap;\n  gap: 20px;\n}\n\n.pos-title {\n  font-size: 20px;\n  color: #60A5FA;\n  margin: 0 0 10px 0;\n  font-weight: 600;\n}\n\n.pos-tags {\n  display: flex;\n  gap: 10px;\n}\n\n.tag {\n  font-size: 12px;\n  background: rgba(96, 165, 250, 0.1);\n  color: #93C5FD;\n  padding: 4px 10px;\n  border-radius: 4px;\n}\n\n.apply-btn {\n  background: transparent;\n  border: 1px solid #F97316;\n  color: #F97316;\n  padding: 8px 24px;\n  border-radius: 20px;\n  font-size: 14px;\n  text-decoration: none;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.apply-btn:hover {\n  background: #F97316;\n  color: white;\n}\n\n.pos-desc {\n  font-size: 15px;\n  color: #CBD5E1;\n  line-height: 1.8;\n}\n\n.pos-desc strong {\n  color: #E2E8F0;\n  display: block;\n  margin-bottom: 8px;\n  margin-top: 15px;\n}\n\n.pos-desc ul {\n  padding-left: 20px;\n  margin: 0;\n}\n\n.pos-desc li {\n  margin-bottom: 6px;\n}\n\n/* Contact HR */\n.hr-contact {\n  text-align: center;\n  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(249, 115, 22, 0.1) 100%);\n  padding: 40px;\n  border-radius: 20px;\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.hr-contact p {\n  color: #94A3B8;\n  margin-bottom: 12px;\n}\n\n.hr-email {\n  display: inline-block;\n  font-size: 24px;\n  font-weight: 700;\n  color: #60A5FA;\n  text-decoration: none;\n  margin-bottom: 12px;\n}\n\n.hr-tip {\n  font-size: 13px !important;\n  color: #64748B !important;\n  margin-bottom: 0 !important;\n}\n\n@media (max-width: 768px) {\n  .content-container {\n    padding: 30px 20px;\n  }\n}\n</style>\n"],"version":3}